<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>通知中心</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      <h2>🤖 AI 自动化</h2>
    </div>
    <nav class="sidebar-nav">
      <a href="/">
        <span class="icon">📊</span>
        <span>仪表盘</span>
      </a>
      <a href="/demo">
        <span class="icon">🎯</span>
        <span>演示中心</span>
      </a>
      <a href="/automations">
        <span class="icon">⚙️</span>
        <span>自动化规则</span>
      </a>
      <a href="/contracts">
        <span class="icon">📄</span>
        <span>合同管理</span>
      </a>
      <a href="/messages">
        <span class="icon">💬</span>
        <span>消息管理</span>
      </a>
      <a href="/reports">
        <span class="icon">📈</span>
        <span>日报管理</span>
      </a>
      <a href="/tasks">
        <span class="icon">✅</span>
        <span>任务管理</span>
      </a>
      <a href="/notifications" class="active">
        <span class="icon">🔔</span>
        <span>通知中心</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/llm-config">
        <span class="icon">🔧</span>
        <span>LLM配置</span>
      </a>
    </div>
  </div>
  
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1>通知中心</h1>
        <div class="subtitle">查看系统通知和提醒</div>
      </div>
      <div class="header-actions">
        <button class="btn btn-secondary" onclick="markAllRead()">全部标为已读</button>
      </div>
    </div>
    
    <div class="card">
      <div class="card-header">
        <span class="card-title">通知列表</span>
      </div>
      <% if ((notifications || []).length === 0) { %>
        <div style="text-align:center; padding:40px; color:var(--text-muted);">暂无通知</div>
      <% } else { %>
        <% (notifications || []).forEach(n => { %>
          <div class="notification-item <%= n.read ? '' : 'unread' %>">
            <div>
              <div style="color:var(--text-primary); font-weight:500;"><%= n.message %></div>
              <div class="notification-time"><%= n.created_at %></div>
            </div>
            <div style="display:flex; flex-direction:column; align-items:flex-end; gap:var(--spacing-sm);">
              <% const typeMap = { 'warning': 'badge-warning', 'success': 'badge-success', 'info': 'badge-info' }; %>
              <span class="badge <%= typeMap[n.type] || 'badge-info' %>"><%= n.channel === 'wechat' ? '微信' : '系统' %></span>
              <% if (!n.read) { %>
                <button class="btn btn-sm btn-primary" onclick="markRead(<%= n.id %>)">标为已读</button>
              <% } %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <script>
    async function markRead(id) {
      await fetch(`/api/notifications/${id}/read`, { method: 'POST' });
      location.reload();
    }
    
    async function markAllRead() {
      const notifications = document.querySelectorAll('.notification-item.unread');
      for (const item of notifications) {
        const id = item.querySelector('button').onclick.toString().match(/markRead\((\d+)\)/)[1];
        await fetch(`/api/notifications/${id}/read`, { method: 'POST' });
      }
      location.reload();
    }
  </script>
</body>
</html>