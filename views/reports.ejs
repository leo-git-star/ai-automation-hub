<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>日报管理</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      <h2>🤖 AI 自动化</h2>
    </div>
    <nav class="sidebar-nav">
      <a href="/">
        <span class="icon">📊</span>
        <span>仪表盘</span>
      </a>
      <a href="/demo">
        <span class="icon">🎯</span>
        <span>演示中心</span>
      </a>
      <a href="/automations">
        <span class="icon">⚙️</span>
        <span>自动化规则</span>
      </a>
      <a href="/contracts">
        <span class="icon">📄</span>
        <span>合同管理</span>
      </a>
      <a href="/messages">
        <span class="icon">💬</span>
        <span>消息管理</span>
      </a>
      <a href="/reports" class="active">
        <span class="icon">📈</span>
        <span>日报管理</span>
      </a>
      <a href="/tasks">
        <span class="icon">✅</span>
        <span>任务管理</span>
      </a>
      <a href="/notifications">
        <span class="icon">🔔</span>
        <span>通知中心</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/llm-config">
        <span class="icon">🔧</span>
        <span>LLM配置</span>
      </a>
    </div>
  </div>
  
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1>日报管理</h1>
        <div class="subtitle">管理日报提交和AI汇总分析</div>
      </div>
    </div>
    
    <div class="card">
      <div class="card-header">
        <span class="card-title">📝 提交日报</span>
      </div>
      <div class="form-group">
        <textarea id="report-content" placeholder="今日完成工作：
1. xxx
2. xxx

明日工作计划：
1. xxx
2. xxx"></textarea>
      </div>
      <button class="btn btn-primary" onclick="submitReport()">提交日报</button>
    </div>
    
    <div class="card">
      <div class="card-header">
        <span class="card-title">📊 AI 汇总分析</span>
      </div>
      <button class="btn btn-primary" onclick="summarizeReports()">汇总最近7天日报</button>
      <div id="summary-result" class="result-box" style="display:none;"></div>
    </div>
    
    <div class="card">
      <div class="card-header">
        <span class="card-title">📋 历史日报</span>
      </div>
      <% (reports || []).forEach(r => { %>
        <div style="background:var(--bg-input); padding:var(--spacing-md); border-radius:var(--border-radius); margin-bottom:var(--spacing-md);">
          <div style="font-weight:600; color:var(--primary-light); margin-bottom:var(--spacing-sm);">📅 <%= r.date %></div>
          <pre style="white-space:pre-wrap; color:var(--text-secondary); font-family:inherit;"><%= r.content %></pre>
        </div>
      <% }) %>
    </div>
  </div>

  <script>
    async function submitReport() {
      const content = document.getElementById('report-content').value;
      if (!content.trim()) { alert('请输入日报内容'); return; }
      
      try {
        await fetch('/api/daily-reports', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content })
        });
        document.getElementById('report-content').value = '';
        alert('日报提交成功');
        location.reload();
      } catch (e) { alert('提交失败'); }
    }
    
    async function summarizeReports() {
      const resultBox = document.getElementById('summary-result');
      resultBox.innerHTML = '<div class="loading"><div class="spinner"></div> AI 正在汇总分析...</div>';
      resultBox.style.display = 'block';
      
      try {
        const res = await fetch('/api/summarize-reports', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        
        if (data.success) {
          resultBox.className = 'result-box success';
          resultBox.innerHTML = `
            <h4 style="margin-bottom:var(--spacing-sm);">✅ 汇总完成（基于 ${data.data.reportCount} 份日报）</h4>
            <div style="color:var(--text-secondary);">${data.data.summary.replace(/\n/g, '<br>')}</div>
          `;
        } else {
          resultBox.className = 'result-box error';
          resultBox.innerHTML = `<p>汇总失败：${data.error}</p>`;
        }
      } catch (e) {
        resultBox.className = 'result-box error';
        resultBox.innerHTML = `<p>请求失败：${e.message}</p>`;
      }
    }
  </script>
</body>
</html>