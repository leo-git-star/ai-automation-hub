<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LLM配置 - AI Automation Hub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      <h2>🤖 AI 自动化</h2>
    </div>
    <nav class="sidebar-nav">
      <a href="/">
        <span class="icon">📊</span>
        <span>仪表盘</span>
      </a>
      <a href="/demo">
        <span class="icon">🎯</span>
        <span>演示中心</span>
      </a>
      <a href="/automations">
        <span class="icon">⚙️</span>
        <span>自动化规则</span>
      </a>
      <a href="/contracts">
        <span class="icon">📄</span>
        <span>合同管理</span>
      </a>
      <a href="/messages">
        <span class="icon">💬</span>
        <span>消息管理</span>
      </a>
      <a href="/reports">
        <span class="icon">📈</span>
        <span>日报管理</span>
      </a>
      <a href="/tasks">
        <span class="icon">✅</span>
        <span>任务管理</span>
      </a>
      <a href="/notifications">
        <span class="icon">🔔</span>
        <span>通知中心</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/llm-config" class="active">
        <span class="icon">🔧</span>
        <span>LLM配置</span>
      </a>
    </div>
  </div>
  
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1>LLM 模型配置</h1>
        <div class="subtitle">配置AI模型参数，启用真实AI处理能力</div>
      </div>
    </div>
    
    <div class="card">
      <div class="card-header">
        <span class="card-title">🤖 模型配置</span>
      </div>
      
      <% if (config.enabled && config.key) { %>
        <div class="result-box success" style="margin-bottom:var(--spacing-lg);">
          ✓ 已配置API Key，将使用真实AI模型进行处理
        </div>
      <% } else { %>
        <div class="result-box warning" style="margin-bottom:var(--spacing-lg);">
          ⚠️ 未配置API Key，当前使用模拟AI响应
        </div>
      <% } %>

      <form id="configForm">
        <div class="form-group">
          <label>选择平台</label>
          <div style="display:flex; gap:var(--spacing-sm); flex-wrap:wrap;">
            <% Object.keys(models.platform_meta).forEach(platform => { %>
              <button type="button" class="btn <%= config.platform === platform ? 'btn-primary' : 'btn-secondary' %>" 
                      data-platform="<%= platform %>">
                <%= models.platform_meta[platform].label %>
              </button>
            <% }) %>
          </div>
          <input type="hidden" id="platform" name="platform" value="<%= config.platform %>">
        </div>

        <div class="form-group">
          <label>选择模型</label>
          <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:var(--spacing-md);">
            <% Object.keys(models.platforms).forEach(platform => { %>
              <% models.platforms[platform].forEach(model => { %>
                <div class="card <%= config.platform === platform && config.model === model.id ? 'selected-model' : '' %>" 
                     style="cursor:pointer; border-color:<%= config.platform === platform && config.model === model.id ? 'var(--primary)' : 'var(--border-color)' %>;"
                     data-platform="<%= platform %>" data-model="<%= model.id %>">
                  <div style="font-weight:600; color:var(--text-primary); margin-bottom:var(--spacing-xs);"><%= model.name %></div>
                  <div class="text-xs text-muted"><%= model.note %></div>
                </div>
              <% }) %>
            <% }) %>
          </div>
          <input type="hidden" id="model" name="model" value="<%= config.model %>">
        </div>

        <div class="form-group">
          <label>API Key</label>
          <input type="password" id="api_key" name="api_key" placeholder="输入您的API Key" value="<%= config.key ? '****************' : '' %>">
          <div class="result-box" style="margin-top:var(--spacing-sm); border-left-color:var(--info);">
            <strong>💡 获取免费API Key：</strong>
            <ul style="margin-top:var(--spacing-sm); padding-left:var(--spacing-lg);">
              <li>智谱AI: <a href="https://open.bigmodel.cn/" target="_blank" style="color:var(--primary-light);">https://open.bigmodel.cn/</a></li>
              <li>硅基流动: <a href="https://www.siliconflow.cn/" target="_blank" style="color:var(--primary-light);">https://www.siliconflow.cn/</a></li>
              <li>Google Gemini: <a href="https://ai.google.dev/" target="_blank" style="color:var(--primary-light);">https://ai.google.dev/</a></li>
            </ul>
          </div>
        </div>

        <button type="submit" class="btn btn-primary">保存配置</button>
      </form>

      <div style="margin-top:var(--spacing-xl); padding-top:var(--spacing-lg); border-top:1px solid var(--border-color);">
        <h3 style="font-size:var(--font-size-base); font-weight:600; margin-bottom:var(--spacing-md); color:var(--text-primary);">测试连接</h3>
        <button class="btn btn-secondary" id="testBtn">测试AI模型</button>
        <div id="testResult" style="margin-top:var(--spacing-md);"></div>
      </div>
    </div>
  </div>

  <script>
    const platformTabs = document.querySelectorAll('[data-platform]');
    const modelItems = document.querySelectorAll('[data-model]');
    const platformInput = document.getElementById('platform');
    const modelInput = document.getElementById('model');

    platformTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        platformTabs.forEach(t => {
          t.classList.remove('btn-primary');
          t.classList.add('btn-secondary');
        });
        tab.classList.remove('btn-secondary');
        tab.classList.add('btn-primary');
        platformInput.value = tab.dataset.platform;
        
        modelItems.forEach(item => {
          if (item.dataset.platform === tab.dataset.platform) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });

    modelItems.forEach(item => {
      item.addEventListener('click', () => {
        modelItems.forEach(i => {
          i.style.borderColor = 'var(--border-color)';
        });
        item.style.borderColor = 'var(--primary)';
        platformInput.value = item.dataset.platform;
        modelInput.value = item.dataset.model;
        
        platformTabs.forEach(tab => {
          if (tab.dataset.platform === item.dataset.platform) {
            tab.click();
          }
        });
      });
    });

    document.getElementById('configForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);
      
      const response = await fetch('/api/llm/config', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      const result = await response.json();
      if (result.success) {
        alert('配置保存成功！');
        location.reload();
      } else {
        alert('保存失败：' + result.error);
      }
    });

    document.getElementById('testBtn').addEventListener('click', async () => {
      const btn = document.getElementById('testBtn');
      const resultDiv = document.getElementById('testResult');
      
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span> 测试中...';
      resultDiv.innerHTML = '';

      try {
        const response = await fetch('/api/demo/classify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: '测试消息：您好，我想了解装修报价' })
        });
        
        const result = await response.json();
        if (result.success) {
          resultDiv.className = 'result-box success';
          resultDiv.innerHTML = `✓ 测试成功！<br>分类结果：${result.data.classification}<br>置信度：${result.data.confidence}`;
        } else {
          resultDiv.className = 'result-box error';
          resultDiv.innerHTML = '✗ 测试失败：' + result.error;
        }
      } catch (error) {
        resultDiv.className = 'result-box error';
        resultDiv.innerHTML = '✗ 测试失败：' + error.message;
      } finally {
        btn.disabled = false;
        btn.innerHTML = '测试AI模型';
      }
    });

    document.querySelectorAll('[data-model]').forEach(item => {
      if (item.dataset.platform !== platformInput.value) {
        item.style.display = 'none';
      }
    });
  </script>
</body>
</html>