<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 自动化工作流 - 演示中心</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      <h2>🤖 AI 自动化</h2>
    </div>
    <nav class="sidebar-nav">
      <a href="/">
        <span class="icon">📊</span>
        <span>仪表盘</span>
      </a>
      <a href="/demo" class="active">
        <span class="icon">🎯</span>
        <span>演示中心</span>
      </a>
      <a href="/automations">
        <span class="icon">⚙️</span>
        <span>自动化规则</span>
      </a>
      <a href="/contracts">
        <span class="icon">📄</span>
        <span>合同管理</span>
      </a>
      <a href="/messages">
        <span class="icon">💬</span>
        <span>消息管理</span>
      </a>
      <a href="/reports">
        <span class="icon">📈</span>
        <span>日报管理</span>
      </a>
      <a href="/tasks">
        <span class="icon">✅</span>
        <span>任务管理</span>
      </a>
      <a href="/notifications">
        <span class="icon">🔔</span>
        <span>通知中心</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/llm-config">
        <span class="icon">🔧</span>
        <span>LLM配置</span>
      </a>
    </div>
  </div>
  
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1>AI 自动化工作流演示</h1>
        <div class="subtitle">体验 AI 如何帮您自动处理重复工作</div>
      </div>
    </div>
    
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">📝</div>
        <div class="stat-number"><%= stats?.totalContracts || 3 %></div>
        <div class="stat-label">合同数量</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">⚠️</div>
        <div class="stat-number"><%= stats?.expiringContracts || 3 %></div>
        <div class="stat-label">即将到期</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">💬</div>
        <div class="stat-number"><%= stats?.recentMessages || 3 %></div>
        <div class="stat-label">客户咨询</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">⚙️</div>
        <div class="stat-number"><%= stats?.activeAutomations || 3 %></div>
        <div class="stat-label">运行中规则</div>
      </div>
    </div>
    
    <div class="grid-3">
      <div class="card" onclick="showDemo('classify')" style="cursor:pointer;">
        <div style="width:64px; height:64px; border-radius:var(--border-radius-lg); display:flex; align-items:center; justify-content:center; font-size:32px; margin-bottom:var(--spacing-lg); background:linear-gradient(135deg, rgba(99,102,241,0.2), rgba(59,130,246,0.2));">📝</div>
        <h3 style="font-size:var(--font-size-lg); font-weight:600; margin-bottom:var(--spacing-md); color:var(--text-primary);">客户咨询自动分类</h3>
        <p style="color:var(--text-secondary); line-height:1.6; margin-bottom:var(--spacing-lg);">AI 自动识别客户消息意图，分类标签，自动回复常见问题，创建跟进任务。</p>
        <button class="btn btn-primary" onclick="event.stopPropagation(); showDemo('classify')">开始演示</button>
      </div>
      <div class="card" onclick="showDemo('due')" style="cursor:pointer;">
        <div style="width:64px; height:64px; border-radius:var(--border-radius-lg); display:flex; align-items:center; justify-content:center; font-size:32px; margin-bottom:var(--spacing-lg); background:linear-gradient(135deg, rgba(16,185,129,0.2), rgba(6,182,212,0.2));">📅</div>
        <h3 style="font-size:var(--font-size-lg); font-weight:600; margin-bottom:var(--spacing-md); color:var(--text-primary);">合同到期自动提醒</h3>
        <p style="color:var(--text-secondary); line-height:1.6; margin-bottom:var(--spacing-lg);">自动检测即将到期的合同，提前发送提醒通知，创建跟进任务，确保合同续签。</p>
        <button class="btn btn-primary" onclick="event.stopPropagation(); showDemo('due')">开始演示</button>
      </div>
      <div class="card" onclick="showDemo('summarize')" style="cursor:pointer;">
        <div style="width:64px; height:64px; border-radius:var(--border-radius-lg); display:flex; align-items:center; justify-content:center; font-size:32px; margin-bottom:var(--spacing-lg); background:linear-gradient(135deg, rgba(139,92,246,0.2), rgba(236,72,153,0.2));">📊</div>
        <h3 style="font-size:var(--font-size-lg); font-weight:600; margin-bottom:var(--spacing-md); color:var(--text-primary);">日报周报自动汇总</h3>
        <p style="color:var(--text-secondary); line-height:1.6; margin-bottom:var(--spacing-lg);">自动收集员工日报，AI 智能汇总分析，生成日报摘要和周报报表，节省80%时间。</p>
        <button class="btn btn-primary" onclick="event.stopPropagation(); showDemo('summarize')">开始演示</button>
      </div>
    </div>
    
    <div id="demo-classify" class="card" style="display:none;">
      <div class="card-header">
        <span class="card-title">📝 客户咨询自动分类</span>
      </div>
      <div class="form-group">
        <label>输入客户咨询消息：</label>
        <textarea id="classify-input" placeholder="例如：您好，我想了解一下100平房子的装修报价..."></textarea>
      </div>
      <button class="btn btn-primary" onclick="runClassifyDemo()">开始分类</button>
      <div id="classify-result" class="result-box" style="display:none;"></div>
      
      <div style="margin-top:var(--spacing-xl);">
        <h4 style="font-size:var(--font-size-base); font-weight:600; margin-bottom:var(--spacing-md); color:var(--text-primary);">历史消息记录：</h4>
        <div style="display:flex; flex-wrap:wrap; gap:var(--spacing-md);">
          <% (recentMessages || []).slice(0, 5).forEach(msg => { %>
            <div class="card" style="min-width:250px; padding:var(--spacing-md);">
              <div class="text-sm text-secondary" style="margin-bottom:var(--spacing-sm);"><%= msg.content %></div>
              <% const classMap = { '报价咨询': 'badge-warning', '工期咨询': 'badge-info', '材料咨询': 'badge-success', '案例查看': 'badge-purple', '预约到店': 'badge-primary', '其他': 'badge-info' }; %>
              <span class="badge <%= classMap[msg.classification] || 'badge-info' %>"><%= msg.classification %></span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
    
    <div id="demo-due" class="card" style="display:none;">
      <div class="card-header">
        <span class="card-title">📅 合同到期自动提醒</span>
      </div>
      <div class="result-box warning" style="margin-bottom:var(--spacing-lg);">
        <p style="font-weight:500;">⚠️ 演示说明：系统会检测未来30天内到期的合同，并自动发送提醒通知。</p>
      </div>
      <button class="btn btn-primary" onclick="runDueDemo()">检测到期合同</button>
      <div id="due-result" class="result-box" style="display:none;"></div>
      
      <div style="margin-top:var(--spacing-xl);">
        <h4 style="font-size:var(--font-size-base); font-weight:600; margin-bottom:var(--spacing-md); color:var(--text-primary);">即将到期的合同：</h4>
        <div class="table-container">
          <table class="table">
            <thead>
              <tr>
                <th>客户名称</th>
                <th>合同编号</th>
                <th>到期日期</th>
                <th>剩余天数</th>
                <th>金额</th>
              </tr>
            </thead>
            <tbody>
              <% (expiringContracts || []).forEach(c => { %>
                <tr>
                  <td><%= c.customer_name %></td>
                  <td><%= c.contract_no %></td>
                  <td><%= c.end_date %></td>
                  <td class="<%= (c.daysLeft || 0) <= 7 ? 'due-7' : 'due-30' %>">
                    <%= (c.daysLeft || 0) %>天
                  </td>
                  <td>¥<%= c.amount.toLocaleString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    
    <div id="demo-summarize" class="card" style="display:none;">
      <div class="card-header">
        <span class="card-title">📊 日报周报自动汇总</span>
      </div>
      <div class="result-box" style="margin-bottom:var(--spacing-lg); border-left-color:var(--info);">
        <p style="font-weight:500;">💡 演示说明：AI 会自动汇总最近7天的日报内容，生成结构化报告。</p>
      </div>
      <button class="btn btn-primary" onclick="runSummarizeDemo()">汇总日报</button>
      <div id="summarize-result" class="result-box" style="display:none;"></div>
    </div>
  </div>

  <script>
    function showDemo(type) {
      document.querySelectorAll('.card').forEach(el => { if(el.id && el.id.startsWith('demo-')) el.style.display = 'none'; });
      document.getElementById(`demo-${type}`).style.display = 'block';
    }
    
    async function runClassifyDemo() {
      const input = document.getElementById('classify-input').value;
      if (!input.trim()) {
        alert('请输入客户咨询消息');
        return;
      }
      
      const resultBox = document.getElementById('classify-result');
      resultBox.innerHTML = '<div class="loading"><div class="spinner"></div> AI 正在分析...</div>';
      resultBox.style.display = 'block';
      
      try {
        const res = await fetch('/api/demo/classify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: input })
        });
        const data = await res.json();
        
        if (data.success) {
          resultBox.className = 'result-box success';
          resultBox.innerHTML = `
            <h4 style="font-size:var(--font-size-base); margin-bottom:var(--spacing-md);">✅ 分类完成</h4>
            <div style="margin-bottom:var(--spacing-md);">
              <span class="badge badge-primary">分类：${data.data.classification}</span>
              <span class="badge badge-success">置信度：${data.data.confidence}</span>
            </div>
            <p style="color:var(--text-secondary);"><strong>摘要：</strong>${data.data.summary || data.data.content}</p>
          `;
        } else {
          resultBox.className = 'result-box error';
          resultBox.innerHTML = `<h4>❌ 分类失败</h4><p>${data.error}</p>`;
        }
      } catch (e) {
        resultBox.className = 'result-box error';
        resultBox.innerHTML = `<h4>❌ 请求失败</h4><p>${e.message}</p>`;
      }
    }
    
    async function runDueDemo() {
      const resultBox = document.getElementById('due-result');
      resultBox.innerHTML = '<div class="loading"><div class="spinner"></div> 正在检测到期合同...</div>';
      resultBox.style.display = 'block';
      
      try {
        const res = await fetch('/api/demo/check-due', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        
        if (data.success) {
          resultBox.className = 'result-box success';
          const executed = data.data.executed || [];
          if (executed.length > 0) {
            let html = `<h4>✅ 检测完成</h4><p>检测到 ${executed.length} 个到期合同，已自动触发提醒。</p><ul>`;
            executed.forEach(e => {
              html += `<li>${e.name} - ${e.result?.message || '已创建通知'}</li>`;
            });
            html += '</ul>';
            resultBox.innerHTML = html;
          } else {
            resultBox.innerHTML = `<h4>✅ 检测完成</h4><p>当前没有需要提醒的到期合同。</p>`;
          }
        } else {
          resultBox.className = 'result-box error';
          resultBox.innerHTML = `<h4>❌ 检测失败</h4><p>${data.error}</p>`;
        }
      } catch (e) {
        resultBox.className = 'result-box error';
        resultBox.innerHTML = `<h4>❌ 请求失败</h4><p>${e.message}</p>`;
      }
    }
    
    async function runSummarizeDemo() {
      const resultBox = document.getElementById('summarize-result');
      resultBox.innerHTML = '<div class="loading"><div class="spinner"></div> AI 正在汇总分析...</div>';
      resultBox.style.display = 'block';
      
      try {
        const res = await fetch('/api/demo/summarize', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        
        if (data.success) {
          resultBox.className = 'result-box success';
          resultBox.innerHTML = `
            <h4>✅ 汇总完成</h4>
            <p style="color:var(--text-secondary);"><strong>汇总报告（基于 ${data.data.reportCount} 份日报）：</strong></p>
            <div style="margin-top:var(--spacing-md); padding:var(--spacing-md); background:var(--bg-input); border-radius:var(--border-radius); border-left:4px solid var(--primary);">
              ${data.data.summary.replace(/\n/g, '<br>')}
            </div>
          `;
        } else {
          resultBox.className = 'result-box error';
          resultBox.innerHTML = `<h4>❌ 汇总失败</h4><p>${data.error}</p>`;
        }
      } catch (e) {
        resultBox.className = 'result-box error';
        resultBox.innerHTML = `<h4>❌ 请求失败</h4><p>${e.message}</p>`;
      }
    }
    
    showDemo('classify');
  </script>
</body>
</html>