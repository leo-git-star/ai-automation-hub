<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>合同管理</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      <h2>🤖 AI 自动化</h2>
    </div>
    <nav class="sidebar-nav">
      <a href="/">
        <span class="icon">📊</span>
        <span>仪表盘</span>
      </a>
      <a href="/demo">
        <span class="icon">🎯</span>
        <span>演示中心</span>
      </a>
      <a href="/automations">
        <span class="icon">⚙️</span>
        <span>自动化规则</span>
      </a>
      <a href="/contracts" class="active">
        <span class="icon">📄</span>
        <span>合同管理</span>
      </a>
      <a href="/messages">
        <span class="icon">💬</span>
        <span>消息管理</span>
      </a>
      <a href="/reports">
        <span class="icon">📈</span>
        <span>日报管理</span>
      </a>
      <a href="/tasks">
        <span class="icon">✅</span>
        <span>任务管理</span>
      </a>
      <a href="/notifications">
        <span class="icon">🔔</span>
        <span>通知中心</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/llm-config">
        <span class="icon">🔧</span>
        <span>LLM配置</span>
      </a>
    </div>
  </div>
  
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1>合同管理</h1>
        <div class="subtitle">管理合同信息和到期提醒</div>
      </div>
      <div class="header-actions">
        <button class="btn btn-primary" onclick="openModal()">+ 新建合同</button>
      </div>
    </div>
    
    <div class="card">
      <div class="card-header">
        <span class="card-title">合同列表</span>
      </div>
      <div class="table-container">
        <table class="table">
          <thead>
            <tr>
              <th>客户名称</th>
              <th>联系方式</th>
              <th>合同编号</th>
              <th>金额</th>
              <th>开始日期</th>
              <th>到期日期</th>
              <th>剩余天数</th>
              <th>状态</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% (contracts || []).forEach(c => { %>
              <tr>
                <td><%= c.customer_name %></td>
                <td><%= c.customer_phone || '-' %></td>
                <td><%= c.contract_no %></td>
                <td>¥<%= c.amount.toLocaleString() %></td>
                <td><%= c.start_date || '-' %></td>
                <td><%= c.end_date %></td>
                <td class="<%= (c.daysLeft || 0) <= 7 ? 'due-7' : (c.daysLeft || 0) <= 30 ? 'due-30' : '' %>">
                  <%= (c.daysLeft || 0) > 0 ? c.daysLeft + '天' : '已到期' %>
                </td>
                <td><span class="badge <%= c.status === 'active' ? 'badge-success' : 'badge-danger' %>"><%= c.status === 'active' ? '有效' : '已终止' %></span></td>
                <td>
                  <button class="btn btn-sm btn-danger" onclick="deleteContract(<%= c.id %>)">删除</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  
  <div class="modal" id="modal">
    <div class="modal-content">
      <h3>新建合同</h3>
      <div class="form-group">
        <label>客户名称 *</label>
        <input type="text" id="customer_name" placeholder="请输入客户名称">
      </div>
      <div class="form-group">
        <label>联系方式</label>
        <input type="text" id="customer_phone" placeholder="请输入联系电话">
      </div>
      <div class="form-group">
        <label>合同编号 *</label>
        <input type="text" id="contract_no" placeholder="请输入合同编号">
      </div>
      <div class="form-group">
        <label>合同金额</label>
        <input type="number" id="amount" placeholder="0.00">
      </div>
      <div class="form-group">
        <label>开始日期</label>
        <input type="date" id="start_date">
      </div>
      <div class="form-group">
        <label>到期日期 *</label>
        <input type="date" id="end_date">
      </div>
      <div class="modal-actions">
        <button class="btn btn-secondary" onclick="closeModal()">取消</button>
        <button class="btn btn-primary" onclick="saveContract()">保存</button>
      </div>
    </div>
  </div>

  <script>
    function openModal() { document.getElementById('modal').classList.add('show'); }
    function closeModal() { document.getElementById('modal').classList.remove('show'); }
    
    async function saveContract() {
      const customer_name = document.getElementById('customer_name').value;
      const customer_phone = document.getElementById('customer_phone').value;
      const contract_no = document.getElementById('contract_no').value;
      const amount = document.getElementById('amount').value;
      const start_date = document.getElementById('start_date').value;
      const end_date = document.getElementById('end_date').value;
      
      if (!customer_name || !contract_no || !end_date) { alert('请填写必填字段'); return; }
      
      try {
        await fetch('/api/contracts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ customer_name, customer_phone, contract_no, amount, start_date, end_date })
        });
        location.reload();
      } catch (e) { alert('保存失败'); }
    }
    
    async function deleteContract(id) {
      if (!confirm('确定删除此合同？')) return;
      await fetch(`/api/contracts/${id}`, { method: 'DELETE' });
      location.reload();
    }
  </script>
</body>
</html>