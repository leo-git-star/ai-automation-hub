<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>自动化规则</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      <h2>🤖 AI 自动化</h2>
    </div>
    <nav class="sidebar-nav">
      <a href="/">
        <span class="icon">📊</span>
        <span>仪表盘</span>
      </a>
      <a href="/demo">
        <span class="icon">🎯</span>
        <span>演示中心</span>
      </a>
      <a href="/automations" class="active">
        <span class="icon">⚙️</span>
        <span>自动化规则</span>
      </a>
      <a href="/contracts">
        <span class="icon">📄</span>
        <span>合同管理</span>
      </a>
      <a href="/messages">
        <span class="icon">💬</span>
        <span>消息管理</span>
      </a>
      <a href="/reports">
        <span class="icon">📈</span>
        <span>日报管理</span>
      </a>
      <a href="/tasks">
        <span class="icon">✅</span>
        <span>任务管理</span>
      </a>
      <a href="/notifications">
        <span class="icon">🔔</span>
        <span>通知中心</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/llm-config">
        <span class="icon">🔧</span>
        <span>LLM配置</span>
      </a>
    </div>
  </div>
  
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1>自动化规则</h1>
        <div class="subtitle">管理和配置自动化工作流规则</div>
      </div>
      <div class="header-actions">
        <button class="btn btn-primary" onclick="openModal()">+ 新建规则</button>
      </div>
    </div>
    
    <div class="card">
      <div class="card-header">
        <span class="card-title">规则列表</span>
      </div>
      <div class="table-container">
        <table class="table">
          <thead>
            <tr>
              <th>规则名称</th>
              <th>触发器</th>
              <th>动作</th>
              <th>状态</th>
              <th>执行次数</th>
              <th>最后执行</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% (automations || []).forEach(a => { %>
              <tr>
                <td><%= a.name %></td>
                <td>
                  <% const triggerMap = { 'event': '事件触发', 'cron': '定时任务', 'due': '到期提醒', 'tagged': '标签触发' }; %>
                  <span class="badge badge-info"><%= triggerMap[a.trigger_type] || a.trigger_type %></span>
                </td>
                <td>
                  <% const actionMap = { 'send_notification': '发送通知', 'create_task': '创建任务', 'run_ai': 'AI处理', 'update_task': '更新任务' }; %>
                  <span class="badge badge-warning"><%= actionMap[a.action_type] || a.action_type %></span>
                </td>
                <td><span class="badge <%= a.enabled ? 'badge-success' : 'badge-danger' %>"><%= a.enabled ? '运行中' : '已停止' %></span></td>
                <td><%= a.run_count %></td>
                <td><%= a.last_run_at || '-' %></td>
                <td>
                  <button class="btn btn-sm btn-secondary" onclick="runRule(<%= a.id %>)">执行</button>
                  <button class="btn btn-sm <%= a.enabled ? 'btn-danger' : 'btn-success' %>" onclick="toggleRule(<%= a.id %>)"><%= a.enabled ? '停止' : '启动' %></button>
                  <button class="btn btn-sm btn-secondary" onclick="deleteRule(<%= a.id %>)">删除</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  
  <div class="modal" id="modal">
    <div class="modal-content">
      <h3>新建自动化规则</h3>
      <div class="form-group">
        <label>规则名称</label>
        <input type="text" id="rule-name" placeholder="例如：客户咨询自动分类">
      </div>
      <div class="form-group">
        <label>触发器类型</label>
        <select id="trigger-type">
          <option value="event">事件触发</option>
          <option value="cron">定时任务</option>
          <option value="due">到期提醒</option>
          <option value="tagged">标签触发</option>
        </select>
      </div>
      <div class="form-group">
        <label>动作类型</label>
        <select id="action-type">
          <option value="send_notification">发送通知</option>
          <option value="create_task">创建任务</option>
          <option value="run_ai">AI处理</option>
          <option value="update_task">更新任务</option>
        </select>
      </div>
      <div class="form-group">
        <label>配置参数（JSON格式）</label>
        <textarea id="action-config" placeholder='{"message": "通知内容"}'></textarea>
      </div>
      <div class="modal-actions">
        <button class="btn btn-secondary" onclick="closeModal()">取消</button>
        <button class="btn btn-primary" onclick="saveRule()">保存</button>
      </div>
    </div>
  </div>

  <script>
    function openModal() { document.getElementById('modal').classList.add('show'); }
    function closeModal() { document.getElementById('modal').classList.remove('show'); }
    
    async function saveRule() {
      const name = document.getElementById('rule-name').value;
      const trigger_type = document.getElementById('trigger-type').value;
      const action_type = document.getElementById('action-type').value;
      const action_config = document.getElementById('action-config').value;
      
      if (!name) { alert('请输入规则名称'); return; }
      
      try {
        await fetch('/api/automations', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, trigger_type, trigger_config: {}, action_type, action_config: JSON.parse(action_config || '{}') })
        });
        location.reload();
      } catch (e) { alert('保存失败'); }
    }
    
    async function runRule(id) {
      await fetch(`/api/automations/${id}/run`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      location.reload();
    }
    
    async function toggleRule(id) {
      await fetch(`/api/automations/${id}/toggle`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      location.reload();
    }
    
    async function deleteRule(id) {
      if (!confirm('确定删除此规则？')) return;
      await fetch(`/api/automations/${id}`, { method: 'DELETE' });
      location.reload();
    }
  </script>
</body>
</html>