<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 自动化工作流 - 管理面板</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      <h2>🤖 AI 自动化</h2>
    </div>
    <nav class="sidebar-nav">
      <a href="/" class="active">
        <span class="icon">📊</span>
        <span>仪表盘</span>
      </a>
      <a href="/demo">
        <span class="icon">🎯</span>
        <span>演示中心</span>
      </a>
      <a href="/automations">
        <span class="icon">⚙️</span>
        <span>自动化规则</span>
      </a>
      <a href="/contracts">
        <span class="icon">📄</span>
        <span>合同管理</span>
      </a>
      <a href="/messages">
        <span class="icon">💬</span>
        <span>消息管理</span>
      </a>
      <a href="/reports">
        <span class="icon">📈</span>
        <span>日报管理</span>
      </a>
      <a href="/tasks">
        <span class="icon">✅</span>
        <span>任务管理</span>
      </a>
      <a href="/notifications">
        <span class="icon">🔔</span>
        <span>通知中心</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/llm-config">
        <span class="icon">🔧</span>
        <span>LLM配置</span>
      </a>
    </div>
  </div>
  
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1>欢迎回来，管理员</h1>
        <div class="subtitle">上次登录：刚刚</div>
      </div>
    </div>
    
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">📝</div>
        <div class="stat-number"><%= stats?.totalContracts || 0 %></div>
        <div class="stat-label">合同总数</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">⚠️</div>
        <div class="stat-number"><%= stats?.expiringContracts || 0 %></div>
        <div class="stat-label">即将到期</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">💬</div>
        <div class="stat-number"><%= stats?.recentMessages || 0 %></div>
        <div class="stat-label">客户咨询</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">⚙️</div>
        <div class="stat-number"><%= stats?.activeAutomations || 0 %></div>
        <div class="stat-label">运行中规则</div>
      </div>
    </div>
    
    <div class="grid-2">
      <div class="card">
        <div class="card-header">
          <span class="card-title">📅 即将到期的合同</span>
          <a href="/contracts" class="btn btn-sm btn-secondary">查看全部</a>
        </div>
        <div class="table-container">
          <table class="table">
            <thead>
              <tr>
                <th>客户名称</th>
                <th>合同编号</th>
                <th>到期日期</th>
                <th>剩余天数</th>
                <th>金额</th>
              </tr>
            </thead>
            <tbody>
              <% (expiringContracts || []).slice(0, 5).forEach(c => { %>
                <tr>
                  <td><%= c.customer_name %></td>
                  <td><%= c.contract_no %></td>
                  <td><%= c.end_date %></td>
                  <td class="<%= (c.daysLeft || 0) <= 7 ? 'due-7' : 'due-30' %>">
                    <%= (c.daysLeft || 0) %>天
                  </td>
                  <td>¥<%= c.amount.toLocaleString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      
      <div class="card">
        <div class="card-header">
          <span class="card-title">🔔 最新通知</span>
          <a href="/notifications" class="btn btn-sm btn-secondary">查看全部</a>
        </div>
        <div style="max-height:300px; overflow-y:auto;">
          <% (notifications || []).slice(0, 5).forEach(n => { %>
            <div class="notification-item <%= n.read ? '' : 'unread' %>">
              <div><%= n.message %></div>
              <div class="notification-time"><%= n.created_at %></div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
    
    <div class="grid-2">
      <div class="card">
        <div class="card-header">
          <span class="card-title">💬 最近客户咨询</span>
          <a href="/messages" class="btn btn-sm btn-secondary">查看全部</a>
        </div>
        <div class="table-container">
          <table class="table">
            <thead>
              <tr>
                <th>内容</th>
                <th>分类</th>
                <th>客户</th>
                <th>时间</th>
              </tr>
            </thead>
            <tbody>
              <% (recentMessages || []).slice(0, 5).forEach(m => { %>
                <tr>
                  <td class="truncate" style="max-width:200px;"><%= m.content %></td>
                  <td>
                    <% const classMap = { '报价咨询': 'badge-warning', '工期咨询': 'badge-info', '材料咨询': 'badge-success', '案例查看': 'badge-purple', '预约到店': 'badge-primary', '其他': 'badge-info' }; %>
                    <span class="badge <%= classMap[m.classification] || 'badge-info' %>"><%= m.classification %></span>
                  </td>
                  <td><%= m.customer_name || '未知' %></td>
                  <td><%= m.created_at %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      
      <div class="card">
        <div class="card-header">
          <span class="card-title">⚙️ 自动化规则状态</span>
          <a href="/automations" class="btn btn-sm btn-secondary">管理规则</a>
        </div>
        <div style="display:flex; flex-direction:column; gap:var(--spacing-lg);">
          <% (automations || []).forEach(a => { %>
            <div>
              <div style="display:flex; justify-content:space-between; margin-bottom:var(--spacing-sm);">
                <span style="font-weight:500;"><%= a.name %></span>
                <span class="badge <%= a.enabled ? 'badge-success' : 'badge-danger' %>"><%= a.enabled ? '运行中' : '已停止' %></span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill" style="width:<%= Math.min(a.run_count * 10, 100) %>%"></div>
              </div>
              <div class="text-xs text-muted mt-sm">已执行 <%= a.run_count %> 次</div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>