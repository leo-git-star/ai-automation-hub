<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>消息管理</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      <h2>🤖 AI 自动化</h2>
    </div>
    <nav class="sidebar-nav">
      <a href="/">
        <span class="icon">📊</span>
        <span>仪表盘</span>
      </a>
      <a href="/demo">
        <span class="icon">🎯</span>
        <span>演示中心</span>
      </a>
      <a href="/automations">
        <span class="icon">⚙️</span>
        <span>自动化规则</span>
      </a>
      <a href="/contracts">
        <span class="icon">📄</span>
        <span>合同管理</span>
      </a>
      <a href="/messages" class="active">
        <span class="icon">💬</span>
        <span>消息管理</span>
      </a>
      <a href="/reports">
        <span class="icon">📈</span>
        <span>日报管理</span>
      </a>
      <a href="/tasks">
        <span class="icon">✅</span>
        <span>任务管理</span>
      </a>
      <a href="/notifications">
        <span class="icon">🔔</span>
        <span>通知中心</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/llm-config">
        <span class="icon">🔧</span>
        <span>LLM配置</span>
      </a>
    </div>
  </div>
  
  <div class="main-content">
    <div class="page-header">
      <div>
        <h1>消息管理</h1>
        <div class="subtitle">管理客户咨询消息和AI分类</div>
      </div>
    </div>
    
    <div class="card">
      <div class="card-header">
        <span class="card-title">🤖 AI 智能分类</span>
      </div>
      <div class="form-group">
        <label>输入客户咨询消息：</label>
        <textarea id="message-input" placeholder="输入客户咨询消息，AI将自动分类..."></textarea>
      </div>
      <button class="btn btn-primary" onclick="classifyMessage()">开始分类</button>
      <div id="classification-result" class="result-box" style="display:none;"></div>
    </div>
    
    <div class="card">
      <div class="card-header">
        <span class="card-title">💬 历史消息记录</span>
      </div>
      <div class="table-container">
        <table class="table">
          <thead>
            <tr>
              <th>内容</th>
              <th>分类</th>
              <th>客户名称</th>
              <th>联系方式</th>
              <th>状态</th>
              <th>时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% (messages || []).forEach(m => { %>
              <tr>
                <td class="truncate" style="max-width:300px;"><%= m.content %></td>
                <td>
                  <% const classMap = { '报价咨询': 'badge-warning', '工期咨询': 'badge-info', '材料咨询': 'badge-success', '案例查看': 'badge-purple', '预约到店': 'badge-primary', '其他': 'badge-info' }; %>
                  <span class="badge <%= classMap[m.classification] || 'badge-info' %>"><%= m.classification %></span>
                </td>
                <td><%= m.customer_name || '-' %></td>
                <td><%= m.customer_phone || '-' %></td>
                <td><span class="badge <%= m.status === 'pending' ? 'badge-warning' : 'badge-success' %>"><%= m.status === 'pending' ? '待处理' : '已处理' %></span></td>
                <td><%= m.created_at %></td>
                <td>
                  <button class="btn btn-sm btn-danger" onclick="deleteMessage(<%= m.id %>)">删除</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    async function classifyMessage() {
      const input = document.getElementById('message-input').value;
      if (!input.trim()) { alert('请输入消息内容'); return; }
      
      const resultBox = document.getElementById('classification-result');
      resultBox.innerHTML = '<div class="loading"><div class="spinner"></div> AI 正在分析...</div>';
      resultBox.style.display = 'block';
      
      try {
        const res = await fetch('/api/messages', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: input })
        });
        const data = await res.json();
        
        if (data.success) {
          resultBox.className = 'result-box success';
          resultBox.innerHTML = `
            <div>
              <span class="badge badge-primary">分类：${data.data.classification}</span>
              <span class="badge badge-success">置信度：${data.data.confidence}</span>
            </div>
            <p style="margin-top:var(--spacing-sm); color:var(--text-secondary);"><strong>摘要：</strong>${data.data.summary || input}</p>
          `;
          document.getElementById('message-input').value = '';
        } else {
          resultBox.className = 'result-box error';
          resultBox.innerHTML = `<p>分类失败：${data.error}</p>`;
        }
      } catch (e) {
        resultBox.className = 'result-box error';
        resultBox.innerHTML = `<p>请求失败：${e.message}</p>`;
      }
    }
    
    async function deleteMessage(id) {
      if (!confirm('确定删除此消息？')) return;
      await fetch(`/api/messages/${id}`, { method: 'DELETE' });
      location.reload();
    }
  </script>
</body>
</html>